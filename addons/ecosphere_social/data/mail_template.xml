<odoo>
    <record id="mail_template_social_digest" model="mail.template">
        <field name="name">Social Initiative Digest</field>
        <field name="model_id" ref="model_ecosphere_initiative"/>
        <field name="subject">Social initiative status update</field>
        <field name="body_html"><![CDATA[
            <p>Hello,</p>
            <p>This is a reminder that the initiative <t t-out="object.name"/> is tracking progress.</p>
            <p>Current impact score: <t t-out="object.impact_score"/></p>
        ]]></field>
    </record>
</odoo>
