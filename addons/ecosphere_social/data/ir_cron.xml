<odoo noupdate="1">
    <record id="ir_cron_social_engagement_update" model="ir.cron">
        <field name="name">Refresh Social Engagement Scores</field>
        <field name="model_id" ref="model_ecosphere_worker"/>
        <field name="state">code</field>
        <field name="code">model.search([]).write({'engagement_score': 0.0})</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">False</field>
    </record>
</odoo>
