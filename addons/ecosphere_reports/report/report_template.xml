<odoo>
    <template id="external_layout_ecosphere_reports">
        <t t-call="web.external_layout">
            <t t-set="company" t-value="res_company"/>
            <div class="page">
                <div class="row mb32">
                    <div class="col-6">
                        <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 60px;"/>
                        <h3>EcoSphere ESG Reporting</h3>
                    </div>
                    <div class="col-6 text-right">
                        <strong t-esc="res_company.name"/>
                        <br/>
                        <span t-esc="res_company.city or ''"/>
                    </div>
                </div>
                <t t-raw="0"/>
            </div>
        </t>
    </template>

    <template id="report_environmental">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Environmental Report</h2>
                        <p><strong>Organization:</strong> <t t-esc="doc.company_id.name or ''"/></p>
                        <p><strong>Department:</strong> <t t-esc="doc.department or 'All'"/></p>
                        <p><strong>Date Range:</strong> <t t-esc="doc.date_from or 'Start'"/> to <t t-esc="doc.date_to or 'End'"/></p>
                        <hr/>
                        <h4>Emissions</h4>
                        <table class="table table-sm">
                            <thead><tr><th>Name</th><th>Date</th><th>Type</th><th>Quantity</th><th>Unit</th></tr></thead>
                            <tbody>
                                <tr t-foreach="doc._get_report_data().get('emission_records', [])" t-as="record">
                                    <td><t t-esc="record.name"/></td>
                                    <td><t t-esc="record.date"/></td>
                                    <td><t t-esc="record.emission_type"/></td>
                                    <td><t t-esc="record.quantity"/></td>
                                    <td><t t-esc="record.unit"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <p><strong>Total Emissions:</strong> <t t-esc="doc._get_report_data().get('emission_total', 0)"/></p>
                        <hr/>
                        <h4>Resources</h4>
                        <table class="table table-sm">
                            <thead><tr><th>Name</th><th>Type</th><th>Quantity</th><th>Unit</th></tr></thead>
                            <tbody>
                                <tr t-foreach="doc._get_report_data().get('resource_records', [])" t-as="record">
                                    <td><t t-esc="record.name"/></td>
                                    <td><t t-esc="record.resource_type"/></td>
                                    <td><t t-esc="record.quantity"/></td>
                                    <td><t t-esc="record.unit"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <p><strong>Total Resources:</strong> <t t-esc="doc._get_report_data().get('resource_total', 0)"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_social">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Social Report</h2>
                        <p><strong>Organization:</strong> <t t-esc="doc.company_id.name or ''"/></p>
                        <p><strong>Employee:</strong> <t t-esc="doc.employee_name or 'All'"/></p>
                        <p><strong>Department:</strong> <t t-esc="doc.department or 'All'"/></p>
                        <hr/>
                        <h4>Employees</h4>
                        <table class="table table-sm">
                            <thead><tr><th>Name</th><th>Role</th><th>Engagement Score</th></tr></thead>
                            <tbody>
                                <tr t-foreach="doc._get_report_data().get('social_records', [])" t-as="record">
                                    <td><t t-esc="record.name"/></td>
                                    <td><t t-esc="record.role"/></td>
                                    <td><t t-esc="record.engagement_score"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <p><strong>Employee Count:</strong> <t t-esc="doc._get_report_data().get('social_count', 0)"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_governance">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Governance Report</h2>
                        <p><strong>Organization:</strong> <t t-esc="doc.company_id.name or ''"/></p>
                        <p><strong>Department:</strong> <t t-esc="doc.department or 'All'"/></p>
                        <hr/>
                        <h4>Policies</h4>
                        <table class="table table-sm">
                            <thead><tr><th>Name</th><th>Type</th><th>Status</th><th>Effective Date</th></tr></thead>
                            <tbody>
                                <tr t-foreach="doc._get_report_data().get('policy_records', [])" t-as="record">
                                    <td><t t-esc="record.name"/></td>
                                    <td><t t-esc="record.policy_type"/></td>
                                    <td><t t-esc="record.status"/></td>
                                    <td><t t-esc="record.effective_date"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <p><strong>Policy Count:</strong> <t t-esc="doc._get_report_data().get('policy_count', 0)"/></p>
                        <hr/>
                        <h4>Compliance</h4>
                        <table class="table table-sm">
                            <thead><tr><th>Name</th><th>Due Date</th><th>Status</th></tr></thead>
                            <tbody>
                                <tr t-foreach="doc._get_report_data().get('compliance_records', [])" t-as="record">
                                    <td><t t-esc="record.name"/></td>
                                    <td><t t-esc="record.due_date"/></td>
                                    <td><t t-esc="record.status"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <p><strong>Compliance Count:</strong> <t t-esc="doc._get_report_data().get('compliance_count', 0)"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_esg_summary">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>ESG Summary Report</h2>
                        <p><strong>Organization:</strong> <t t-esc="doc.company_id.name or ''"/></p>
                        <p><strong>Department:</strong> <t t-esc="doc.department or 'All'"/></p>
                        <p><strong>Employee:</strong> <t t-esc="doc.employee_name or 'All'"/></p>
                        <p><strong>Date Range:</strong> <t t-esc="doc.date_from or 'Start'"/> to <t t-esc="doc.date_to or 'End'"/></p>
                        <hr/>
                        <h4>Summary Metrics</h4>
                        <table class="table table-sm">
                            <thead><tr><th>Metric</th><th>Category</th><th>Score</th><th>Status</th></tr></thead>
                            <tbody>
                                <tr t-foreach="doc._get_report_data().get('metric_records', [])" t-as="record">
                                    <td><t t-esc="record.name"/></td>
                                    <td><t t-esc="record.category"/></td>
                                    <td><t t-esc="record.score"/></td>
                                    <td><t t-esc="record.state"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <p><strong>Metric Count:</strong> <t t-esc="doc._get_report_data().get('metric_count', 0)"/></p>
                        <p><strong>Average Score:</strong> <t t-esc="doc._get_report_data().get('metric_average_score', 0)"/></p>
                        <hr/>
                        <h4>Highlights</h4>
                        <ul>
                            <li>Environmental records: <t t-esc="doc._get_report_data().get('emission_count', 0)"/></li>
                            <li>Social records: <t t-esc="doc._get_report_data().get('social_count', 0)"/></li>
                            <li>Governance records: <t t-esc="doc._get_report_data().get('policy_count', 0) + doc._get_report_data().get('compliance_count', 0)"/></li>
                        </ul>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
