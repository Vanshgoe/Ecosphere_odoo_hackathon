<odoo><record id="action_esg_report" model="ir.actions.report"><field name="name">ESG Report</field><field name="model">ecosphere.report.wizard</field><field name="report_type">qweb-pdf</field><field name="report_name">ecosphere_reports.esg_document</field><field name="report_file">ecosphere_reports.esg_document</field></record><record id="action_esg_xlsx" model="ir.actions.report"><field name="name">ESG XLSX Report</field><field name="model">ecosphere.report.wizard</field><field name="report_type">xlsx</field><field name="report_name">ecosphere_reports.esg_xlsx</field><field name="report_file">esg_report</field></record><template id="esg_document"><t t-foreach="docs" t-as="doc"><t t-call="web.external_layout"><div class="page"><h2>EcoSphere ESG Report</h2><p><strong>Company:</strong> <span t-esc="doc.company_id.name"/></p><p><strong>Period:</strong> <span t-esc="doc.date_from"/> – <span t-esc="doc.date_to"/></p><t t-set="score" t-value="doc.env['ecosphere.esg.score'].search([('company_id','=',doc.company_id.id)],limit=1)"/><table class="table table-sm"><thead><tr><th>Environmental</th><th>Social</th><th>Governance</th><th>Overall</th></tr></thead><tbody><tr><td t-esc="score.environmental_score if score else 0"/><td t-esc="score.social_score if score else 0"/><td t-esc="score.governance_score if score else 0"/><td t-esc="score.overall_score if score else 0"/></tr></tbody></table></div></t></t></template></odoo>
