<odoo>

    <record id="module_category_ecosphere" model="ir.module.category">
        <field name="name">EcoSphere</field>
    </record>

    <record id="group_user" model="res.groups">
        <field name="name">EcoSphere User</field>
        <field name="category_id" ref="module_category_ecosphere"/>
    </record>

    <record id="group_manager" model="res.groups">
        <field name="name">EcoSphere Manager</field>
        <field name="category_id" ref="module_category_ecosphere"/>
        <field name="implied_ids" eval="[(4, ref('group_user'))]"/>
    </record>

    <record id="group_officer" model="res.groups">
        <field name="name">EcoSphere ESG Officer</field>
        <field name="category_id" ref="module_category_ecosphere"/>
        <field name="implied_ids" eval="[(4, ref('group_manager'))]"/>
    </record>

    <record id="group_auditor" model="res.groups">
        <field name="name">EcoSphere Auditor</field>
        <field name="category_id" ref="module_category_ecosphere"/>
    </record>

    <record id="group_admin" model="res.groups">
        <field name="name">EcoSphere Administrator</field>
        <field name="category_id" ref="module_category_ecosphere"/>

        <field name="implied_ids"
               eval="[
                   (4, ref('group_officer')),
                   (4, ref('group_auditor'))
               ]"/>
    </record>

</odoo>