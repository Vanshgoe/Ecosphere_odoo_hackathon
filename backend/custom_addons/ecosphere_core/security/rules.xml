    <record id="rule_snapshot_company" model="ir.rule"><field name="name">EcoSphere snapshot company isolation</field><field name="model_id" ref="model_ecosphere_esg_score_snapshot"/><field name="domain_force">[('company_id', 'in', company_ids)]</field><field name="groups" eval="[(4, ref('group_user'))]"/></record>
