<odoo>

    <!-- LIST VIEW -->
    <record id="goal_list" model="ir.ui.view">
        <field name="name">ecosphere.esg.goal.list</field>
        <field name="model">ecosphere.esg.goal</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category_id"/>
                <field name="metric_id"/>
                <field name="target_value"/>
                <field name="current_value"/>
                <field name="progress_percentage"/>
                <field name="status"/>
                <field name="responsible_user_id"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="goal_form" model="ir.ui.view">
        <field name="name">ecosphere.esg.goal.form</field>
        <field name="model">ecosphere.esg.goal</field>
        <field name="arch" type="xml">
            <form string="ESG Goal">

                <sheet>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Reduce Carbon Emissions by 20%"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Goal Information">
                            <field name="company_id"/>
                            <field name="category_id"/>
                            <field name="metric_id"/>
                            <field name="responsible_user_id"/>
                            <field name="status"/>
                        </group>

                        <group string="Target Information">
                            <field name="baseline_value"/>
                            <field name="target_value"/>
                            <field name="current_value"/>
                            <field name="progress_percentage" readonly="1"/>
                        </group>
                    </group>

                    <group string="Timeline">
                        <group>
                            <field name="start_date"/>
                        </group>

                        <group>
                            <field name="target_date"/>
                        </group>
                    </group>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <!-- WINDOW ACTION -->
    <record id="action_goals" model="ir.actions.act_window">
        <field name="name">Goals</field>
        <field name="res_model">ecosphere.esg.goal</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENUS -->
    <menuitem
        id="menu_root"
        name="EcoSphere"
        action="action_goals"
        sequence="10"
    />

    <menuitem
        id="menu_goals"
        name="ESG Goals"
        parent="menu_root"
        action="action_goals"
        sequence="10"
    />

</odoo>
